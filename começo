  document.getElementById('mtWpp').href = 'https://wa.me/5511964552081?text=' + wpp;
  document.getElementById('modalTiragem').classList.add('open');
}
function fecharTiragem() {
  document.getElementById('modalTiragem').classList.remove('open');
}

</script>


