<script>
// ===== ESTRELAS NO CANVAS =====
const canvas = document.getElementById('stars-canvas');
const ctx = canvas.getContext('2d');

function resizeCanvas() {
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
}
resizeCanvas();
window.addEventListener('resize', () => { resizeCanvas(); drawStars(); });

const stars = [];
function generateStars() {
  stars.length = 0;
  const count = Math.floor((canvas.width * canvas.height) / 3000);
  for (let i = 0; i < count; i++) {
    stars.push({
      x: Math.random() * canvas.width,
      y: Math.random() * canvas.height,
      r: Math.random() * 1.8 + 0.2,
      alpha: Math.random() * 0.8 + 0.2,
      speed: Math.random() * 0.005 + 0.002,
      phase: Math.random() * Math.PI * 2,
      color: Math.random() > 0.85 ? '#c9a84c' : (Math.random() > 0.7 ? '#8ab4f8' : '#e8eeff')
    });
  }
}

let animFrame;
function drawStars() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  const time = Date.now() / 1000;
  stars.forEach(s => {
    const a = s.alpha * (0.6 + 0.4 * Math.sin(time * s.speed * 100 + s.phase));
    ctx.beginPath();
    ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
    ctx.fillStyle = s.color.replace(')', `,${a})`).replace('rgb', 'rgba').replace('#e8eeff', `rgba(232,238,255,${a})`).replace('#c9a84c', `rgba(201,168,76,${a})`).replace('#8ab4f8', `rgba(138,180,248,${a})`);
    ctx.fill();
  });
  animFrame = requestAnimationFrame(drawStars);
}

// Corrigir coloração
function drawStarsFixed() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  const time = Date.now() / 1000;
  stars.forEach(s => {
    const a = s.alpha * (0.5 + 0.5 * Math.sin(time * s.speed * 80 + s.phase));
    ctx.beginPath();
    ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
    if (s.color === '#c9a84c') ctx.fillStyle = `rgba(201,168,76,${a})`;
    else if (s.color === '#8ab4f8') ctx.fillStyle = `rgba(138,180,248,${a})`;
    else ctx.fillStyle = `rgba(180,195,240,${a*0.7})`;
    ctx.fill();
  });
  requestAnimationFrame(drawStarsFixed);
}

generateStars();
drawStarsFixed();

// ===== PARTÍCULAS FLUTUANTES =====
const particlesEl = document.getElementById('particles');
for (let i = 0; i < 20; i++) {
  const p = document.createElement('div');
  p.classList.add('particle');
  p.style.left = Math.random() * 100 + '%';
  p.style.animationDuration = (Math.random() * 15 + 10) + 's';
  p.style.animationDelay = (Math.random() * 15) + 's';
  p.style.width = p.style.height = (Math.random() * 3 + 1) + 'px';
  p.style.opacity = Math.random() * 0.6;
  particlesEl.appendChild(p);
}

// ===== SCROLL REVEAL =====
const revealObserver = new IntersectionObserver((entries) => {
  entries.forEach((e) => {
    if (e.isIntersecting) {
      e.target.classList.add('visible');
    }
  });
}, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

// Reveal geral
document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

// Títulos
document.querySelectorAll('.section-title').forEach(el => revealObserver.observe(el));

// Cards de serviço com delay escalonado
document.querySelectorAll('.service-card').forEach((el, i) => {
  el.style.transitionDelay = `${i * 80}ms`;
  revealObserver.observe(el);
});

// Highlight cards
document.querySelectorAll('.highlight-card').forEach((el, i) => {
  el.style.transitionDelay = `${i * 120}ms`;
  revealObserver.observe(el);
});

// FAQ items
document.querySelectorAll('.faq-item').forEach((el, i) => {
  el.style.transitionDelay = `${i * 70}ms`;
  revealObserver.observe(el);
});

// ===== CURSOR EFEITO ESTRELA =====
document.addEventListener('mousemove', (e) => {
  if (Math.random() > 0.85) {
    const spark = document.createElement('div');
    spark.style.cssText = `
      position:fixed; left:${e.clientX}px; top:${e.clientY}px;
      width:4px; height:4px; background:rgba(201,168,76,0.8);
      border-radius:50%; pointer-events:none; z-index:9999;
      animation: sparkle 0.6s ease forwards;
    `;
    document.body.appendChild(spark);
    setTimeout(() => spark.remove(), 600);
  }
});

const style = document.createElement('style');
style.textContent = `@keyframes sparkle { 0%{transform:scale(1);opacity:1} 100%{transform:scale(0) translateY(-20px);opacity:0} }`;
document.head.appendChild(style);


// Depoimentos reveal
document.querySelectorAll('.depo-card').forEach((el, i) => {
  el.style.transitionDelay = `${i * 100}ms`;
  revealObserver.observe(el);
});

// FAQ toggle
function toggleFaq(btn) {
  const item = btn.parentElement;
  const isOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
  if (!isOpen) item.classList.add('open');
}

// Botão voltar ao topo
const backBtn = document.getElementById('backToTop');
window.addEventListener('scroll', () => {
  backBtn.classList.toggle('visible', window.scrollY > 400);
});


// ===== LOADER =====
const phrases = [
  'Geovana está conectando com o espiritual...',
  'As cartas da Geovana estão sendo preparadas...',
  'O baralho cigano da Geovana desperta...',
  'Geovana abre os caminhos para você...',
  'Sua leitura com Geovana começa em breve...',
  'A cigana revela o que o coração precisa ver...',
  'Deixe Geovana iluminar o seu caminho...'
];
let pi = 0;
const phraseEl = document.getElementById('loaderPhrase');
const phraseInterval = setInterval(() => {
  pi = (pi + 1) % phrases.length;
  phraseEl.style.opacity = '0';
  setTimeout(() => {
    phraseEl.textContent = phrases[pi];
    phraseEl.style.transition = 'opacity 0.5s';
    phraseEl.style.opacity = '1';
  }, 300);
}, 200);

window.addEventListener('load', () => {
  setTimeout(() => {
    clearInterval(phraseInterval);
    document.getElementById('loader').classList.add('hide');
  }, 800);
});


// Modal tiragem
function abrirTiragem(el) {
  var nome = el.getAttribute('data-nome');
