<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🔮 Cartomancia Mística</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Cinzel:wght@400;600&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #c9a84c;
    --gold-light: #f0d080;
    --gold-dark: #8a6a1e;
    --deep-blue: #020408;
    --mid-blue: #060d20;
    --purple: #0e0520;
    --star-white: #e8eeff;
    --mystic-blue: #4a6fa5;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: #010306;
    color: var(--star-white);
    font-family: 'EB Garamond', serif;
    overflow-x: hidden;
    cursor: default;
  }

  /* ===== CANVAS ESTRELAS ===== */
  /* ===== LOADER ===== */
  #loader {
    position: fixed;
    inset: 0;
    background: #010306;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 24px;
    transition: opacity 0.8s ease, visibility 0.8s ease;
  }
  #loader.hide {
    opacity: 0;
    visibility: hidden;
  }
  .loader-crystal {
    font-size: 64px;
    animation: loader-pulse 1.5s ease-in-out infinite;
    filter: drop-shadow(0 0 30px rgba(201,168,76,0.7));
  }
  @keyframes loader-pulse {
    0%, 100% { transform: scale(1);   filter: drop-shadow(0 0 20px rgba(201,168,76,0.5)); }
    50%       { transform: scale(1.1); filter: drop-shadow(0 0 55px rgba(201,168,76,1));   }
  }
  .loader-title {
    font-family: 'Cinzel Decorative', serif;
    font-size: clamp(1.2rem, 4vw, 2rem);
    background: linear-gradient(135deg, #8a6a1e, #f0d080, #c9a84c, #f0d080);
    background-size: 300% 300%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 2.5s ease infinite;
    letter-spacing: 2px;
  }
  .loader-subtitle {
    font-family: 'Cinzel', serif;
    font-size: 0.8rem;
    color: rgba(201,168,76,0.5);
    letter-spacing: 4px;
    text-transform: uppercase;
  }
  /* Barra de progresso mística */
  .loader-bar-wrap {
    width: 200px;
    height: 2px;
    background: rgba(201,168,76,0.1);
    border-radius: 2px;
    overflow: hidden;
    position: relative;
  }
  .loader-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, transparent, var(--gold), #f0d080);
    border-radius: 2px;
    animation: load-progress 0.7s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    box-shadow: 0 0 10px rgba(201,168,76,0.6);
  }
  @keyframes load-progress {
    0%   { width: 0%; }
    60%  { width: 75%; }
    100% { width: 100%; }
  }
  /* Estrelinhas giratórias ao redor da bola */
  .loader-stars {
    position: relative;
    width: 100px;
    height: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .loader-orbit {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px dashed rgba(201,168,76,0.2);
    animation: orbit-spin 4s linear infinite;
  }
  .loader-orbit-dot {
    position: absolute;
    top: -3px;
    left: 50%;
    transform: translateX(-50%);
    width: 6px; height: 6px;
    background: var(--gold);
    border-radius: 50%;
    box-shadow: 0 0 8px rgba(201,168,76,0.8);
  }
  .loader-orbit-2 {
    inset: 10px;
    animation: orbit-spin 2.5s linear infinite reverse;
    border-color: rgba(201,168,76,0.15);
  }
  .loader-orbit-dot-2 {
    top: -2px;
    width: 4px; height: 4px;
    background: #f0d080;
  }
  @keyframes orbit-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  /* Frases místicas rotativas */
  .loader-phrase {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-size: 0.95rem;
    color: rgba(232,238,255,0.5);
    height: 20px;
    overflow: hidden;
    text-align: center;
  }

  #stars-canvas {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  /* ===== PARTÍCULAS FLUTUANTES ===== */
  .particles {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
  }
  .particle {
    position: absolute;
    width: 3px; height: 3px;
    background: var(--gold-light);
    border-radius: 50%;
    animation: float-up linear infinite;
    opacity: 0;
  }
  @keyframes float-up {
    0% { transform: translateY(100vh) translateX(0); opacity: 0; }
    10% { opacity: 0.8; }
    90% { opacity: 0.4; }
    100% { transform: translateY(-10vh) translateX(40px); opacity: 0; }
  }

  /* ===== LAYOUT PRINCIPAL ===== */
  .content {
    position: relative;
    z-index: 2;
  }

  /* ===== HEADER HERO ===== */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 40px 20px;
    position: relative;
  }

  .hero-cigana {
    position: absolute;
    bottom: 0;
    right: 0;
    height: 75%;
    max-height: 550px;
    opacity: 0.18;
    pointer-events: none;
    mask-image: linear-gradient(to left, rgba(0,0,0,0.6), transparent 70%),
                linear-gradient(to top, transparent 0%, black 20%);
    -webkit-mask-image: linear-gradient(to left, rgba(0,0,0,0.5) 0%, transparent 65%);
    filter: sepia(0.4) hue-rotate(20deg) saturate(0.8);
    animation: float-cigana 7s ease-in-out infinite alternate;
  }
  @keyframes float-cigana {
    from { transform: translateY(0px); }
    to   { transform: translateY(-12px); }
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 50%, rgba(30,50,100,0.08) 0%, transparent 70%);
  }

  .crystal-ball {
    font-size: 80px;
    animation: pulse-glow 3s ease-in-out infinite;
    margin-bottom: 20px;
    filter: drop-shadow(0 0 30px rgba(201,168,76,0.6));
  }
  @keyframes pulse-glow {
    0%, 100% { transform: scale(1); filter: drop-shadow(0 0 20px rgba(201,168,76,0.5)); }
    50% { transform: scale(1.08); filter: drop-shadow(0 0 50px rgba(201,168,76,0.9)); }
  }

  .hero-title {
    font-family: 'Cinzel Decorative', serif;
    font-size: clamp(2rem, 6vw, 4.5rem);
    font-weight: 900;
    background: linear-gradient(135deg, var(--gold-dark), var(--gold-light), var(--gold), var(--gold-light));
    background-size: 300% 300%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 4s ease infinite;
    line-height: 1.2;
    text-shadow: none;
    margin-bottom: 10px;
  }
  @keyframes shimmer {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .hero-subtitle {
    font-family: 'Cinzel', serif;
    font-size: clamp(0.9rem, 2vw, 1.3rem);
    color: var(--gold);
    letter-spacing: 4px;
    text-transform: uppercase;
    margin-bottom: 20px;
    opacity: 0.9;
  }

  .divider {
    width: 200px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    margin: 20px auto;
    position: relative;
  }
  .divider::before {
    content: '✦';
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    color: var(--gold);
    font-size: 14px;
    background: #010306;
    padding: 0 8px;
  }

  .hero-desc {
    max-width: 600px;
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-style: italic;
    color: rgba(232,238,255,0.85);
    line-height: 1.8;
    margin-bottom: 30px;
  }

  .contact-btn {
    display: inline-block;
    padding: 16px 44px;
    background: linear-gradient(135deg, var(--gold-dark), var(--gold), var(--gold-light));
    color: var(--deep-blue);
    font-family: 'Cinzel', serif;
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
    box-shadow: 0 0 30px rgba(201,168,76,0.3);
  }
  .contact-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 30%, rgba(255,255,255,0.3) 50%, transparent 70%);
    transform: translateX(-100%);
    transition: transform 0.5s ease;
  }
  .contact-btn:hover::before { transform: translateX(100%); }
  .contact-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 40px rgba(201,168,76,0.5); }

  /* ===== SEÇÃO SERVIÇOS ===== */
  .section {
    padding: 80px 20px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-title {
    font-family: 'Cinzel Decorative', serif;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    text-align: center;
    color: var(--gold);
    margin-bottom: 60px;
    position: relative;
  }
  .section-title::after {
    content: '';
    display: block;
    width: 100px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    margin: 16px auto 0;
  }

  /* ===== CARDS DE SERVIÇO ===== */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
  }

  .service-card {
    background: linear-gradient(145deg, rgba(3,7,18,0.98), rgba(10,4,24,0.97));
    border: 1px solid rgba(201,168,76,0.3);
    border-radius: 4px;
    padding: 36px 30px;
    position: relative;
    overflow: hidden;
    transition: all 0.4s ease;
    cursor: pointer;
  }
  .service-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at top, rgba(201,168,76,0.08) 0%, transparent 60%);
    pointer-events: none;
  }
  .service-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .service-card:hover {
    transform: translateY(-6px);
    border-color: rgba(201,168,76,0.7);
    box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 40px rgba(201,168,76,0.15);
  }
  .service-card:hover::after { opacity: 1; }

  .card-icon {
    font-size: 48px;
    margin-bottom: 16px;
    display: block;
    filter: drop-shadow(0 0 15px rgba(201,168,76,0.5));
  }
  .card-title {
    font-family: 'Cinzel', serif;
    font-size: 1.3rem;
    color: var(--gold-light);
    margin-bottom: 12px;
    font-weight: 600;
  }
  .card-tagline {
    font-style: italic;
    color: rgba(232,238,255,0.7);
    font-size: 0.95rem;
    margin-bottom: 20px;
    line-height: 1.6;
  }
  .card-reveals {
    margin-bottom: 20px;
  }
  .card-reveals-title {
    font-family: 'Cinzel', serif;
    font-size: 0.85rem;
    color: var(--gold);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .card-reveals ul {
    list-style: none;
  }
  .card-reveals ul li {
    padding: 5px 0;
    font-size: 0.95rem;
    color: rgba(232,238,255,0.85);
    line-height: 1.5;
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }
  .card-reveals ul li::before {
    content: '✦';
    color: var(--gold);
    font-size: 10px;
    margin-top: 5px;
    flex-shrink: 0;
  }

  .card-price {
    display: inline-block;
    padding: 10px 24px;
    background: linear-gradient(135deg, rgba(201,168,76,0.15), rgba(201,168,76,0.05));
    border: 1px solid rgba(201,168,76,0.4);
    border-radius: 2px;
    font-family: 'Cinzel', serif;
    font-size: 1.2rem;
    color: var(--gold-light);
    font-weight: 600;
    margin-top: 10px;
  }

  /* ===== CARD DESTAQUE (Perguntas Simples) ===== */
  .highlight-section {
    padding: 60px 20px;
    text-align: center;
  }
  .highlight-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    max-width: 700px;
    margin: 0 auto;
  }
  .highlight-card {
    background: linear-gradient(145deg, rgba(2,5,14,0.99), rgba(6,2,16,0.98));
    border: 1px solid rgba(201,168,76,0.5);
    border-radius: 4px;
    padding: 32px 24px;
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
  }
  .highlight-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(201,168,76,0.05) 0%, transparent 70%);
  }
  .highlight-card:hover {
    border-color: var(--gold);
    box-shadow: 0 0 50px rgba(201,168,76,0.2);
    transform: translateY(-4px);
  }
  .highlight-card .card-title {
    font-size: 1.1rem;
    margin-bottom: 8px;
  }
  .highlight-card p {
    font-style: italic;
    color: rgba(232,238,255,0.7);
    font-size: 0.9rem;
    margin-bottom: 16px;
  }

  /* ===== SEÇÃO CONTATO ===== */
  .contact-section {
    padding: 80px 20px;
    text-align: center;
    position: relative;
  }
  .contact-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 80% at 50% 50%, rgba(20,30,70,0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .contact-info {
    margin: 30px auto;
    max-width: 500px;
  }
  .contact-item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 16px;
    margin: 10px 0;
    background: rgba(2,5,14,0.85);
    border: 1px solid rgba(201,168,76,0.2);
    border-radius: 2px;
    font-size: 1.1rem;
    transition: all 0.3s ease;
  }
  .contact-item:hover {
    border-color: rgba(201,168,76,0.5);
    background: rgba(201,168,76,0.05);
  }
  .contact-item span { color: var(--gold); font-size: 1.3rem; }
  .contact-item a {
    color: var(--star-white);
    text-decoration: none;
    font-family: 'Cinzel', serif;
    letter-spacing: 1px;
  }
  .contact-item a:hover { color: var(--gold-light); }

  /* ===== FOOTER ===== */
  /* ===== DEPOIMENTOS ===== */
  .depo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .depo-card {
    background: linear-gradient(145deg, rgba(3,7,18,0.98), rgba(10,4,24,0.97));
    border: 1px solid rgba(201,168,76,0.18);
    border-radius: 4px;
    padding: 28px 24px;
    position: relative;
    overflow: hidden;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.22,1,0.36,1), transform 0.8s cubic-bezier(0.22,1,0.36,1), border-color 0.3s ease;
  }
  .depo-card.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .depo-card:hover { border-color: rgba(201,168,76,0.4); }
  .depo-card::before {
    content: '"';
    position: absolute;
    top: -10px; left: 16px;
    font-family: 'Cinzel Decorative', serif;
    font-size: 80px;
    color: rgba(201,168,76,0.06);
    line-height: 1;
    pointer-events: none;
  }
  .depo-stars {
    color: var(--gold);
    font-size: 1rem;
    letter-spacing: 2px;
    margin-bottom: 14px;
  }
  .depo-text {
    font-size: 1rem;
    line-height: 1.85;
    color: rgba(232,238,255,0.78);
    font-style: italic;
    margin-bottom: 20px;
  }
  .depo-author {
    display: flex;
    align-items: center;
    gap: 12px;
    border-top: 1px solid rgba(201,168,76,0.1);
    padding-top: 16px;
  }
  .depo-avatar {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(201,168,76,0.3), rgba(201,168,76,0.05));
    border: 1px solid rgba(201,168,76,0.3);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem;
    flex-shrink: 0;
  }
  .depo-name {
    font-family: 'Cinzel', serif;
    font-size: 0.85rem;
    color: var(--gold);
    letter-spacing: 1px;
  }
  .depo-type {
    font-size: 0.8rem;
    color: rgba(232,238,255,0.4);
    font-style: italic;
  }
  .depo-badge {
    display: inline-block;
    padding: 3px 10px;
    background: rgba(201,168,76,0.08);
    border: 1px solid rgba(201,168,76,0.2);
    border-radius: 20px;
    font-size: 0.72rem;
    font-family: 'Cinzel', serif;
    color: rgba(201,168,76,0.6);
    letter-spacing: 1px;
    margin-bottom: 14px;
  }

  /* ===== BOTÕES DE TIRAGEM ===== */
  .tiragem-btns {
    display: flex;
    gap: 10px;
    margin-top: 16px;
    flex-wrap: wrap;
  }
  .btn-wpp, .btn-insta {
    flex: 1;
    min-width: 110px;
    padding: 10px 12px;
    border-radius: 3px;
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    letter-spacing: 1px;
    text-decoration: none;
    text-align: center;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }
  .btn-wpp {
    background: linear-gradient(135deg, rgba(37,211,102,0.12), rgba(37,211,102,0.04));
    border: 1px solid rgba(37,211,102,0.4);
    color: #25d366;
  }
  .btn-wpp:hover {
    background: rgba(37,211,102,0.2);
    border-color: #25d366;
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(37,211,102,0.2);
  }
  .btn-insta {
    background: linear-gradient(135deg, rgba(201,168,76,0.12), rgba(201,168,76,0.04));
    border: 1px solid rgba(201,168,76,0.4);
    color: #c9a84c;
  }
  .btn-insta:hover {
    background: rgba(201,168,76,0.2);
    border-color: var(--gold-light);
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(201,168,76,0.2);
  }

  /* ===== MODAL TIRAGEM ===== */
  .modal-tiragem-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.88);
    backdrop-filter: blur(6px);
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .modal-tiragem-overlay.open { opacity: 1; pointer-events: all; }
  .modal-tiragem {
    background: linear-gradient(145deg, #02050e, #06021a);
    border: 1px solid rgba(201,168,76,0.4);
    border-radius: 6px;
    max-width: 400px;
    width: 100%;
    padding: 36px 28px;
    position: relative;
    transform: translateY(30px) scale(0.97);
    transition: transform 0.3s ease;
    text-align: center;
  }
  .modal-tiragem-overlay.open .modal-tiragem { transform: translateY(0) scale(1); }
  .modal-tiragem::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }
  .modal-tiragem-close {
    position: absolute; top: 12px; right: 16px;
    background: none; border: none;
    color: rgba(201,168,76,0.5); font-size: 1.3rem; cursor: pointer; transition: color 0.2s;
  }
  .modal-tiragem-close:hover { color: var(--gold); }
  .modal-tiragem-icon { font-size: 44px; margin-bottom: 12px; filter: drop-shadow(0 0 12px rgba(201,168,76,0.5)); }
  .modal-tiragem-nome { font-family: 'Cinzel', serif; font-size: 1.1rem; color: var(--gold-light); margin-bottom: 4px; }
  .modal-tiragem-preco { font-family: 'Cinzel', serif; font-size: 1.3rem; color: var(--gold); margin-bottom: 20px; font-weight: 600; }
  .modal-tiragem-divider { width: 80px; height: 1px; background: linear-gradient(90deg, transparent, var(--gold), transparent); margin: 0 auto 20px; }
  .modal-tiragem-label { font-family: 'Cinzel', serif; font-size: 0.75rem; color: rgba(201,168,76,0.5); letter-spacing: 3px; text-transform: uppercase; margin-bottom: 14px; }
  .modal-tiragem-btns { display: flex; flex-direction: column; gap: 12px; }
  .modal-btn-wpp, .modal-btn-insta {
    padding: 14px 20px; border-radius: 3px;
